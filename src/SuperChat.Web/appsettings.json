{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SuperChatDb": "Host=localhost;Port=5432;Database=superchat_app;Username=postgres;Password=postgres"
  },
  "Persistence": {
    "Provider": "Postgres",
    "AutoInitialize": true,
    "DatabaseName": "superchat_app"
  },
  "Chunking": {
    "Enabled": true,
    "PollSeconds": 5,
    "MaxGapMinutes": 15,
    "MaxMessagesPerChunk": 8,
    "MaxChunkCharacters": 1600
  },
  "ChunkIndexing": {
    "Enabled": true,
    "PollSeconds": 10,
    "BatchSize": 20
  },
  "MeetingProjection": {
    "Enabled": true,
    "PollSeconds": 15
  },
  "Retrieval": {
    "Enabled": true,
    "PrefetchLimit": 24,
    "ResultLimit": 8
  },
  "ChatAnswering": {
    "Enabled": true,
    "MaxContextChunks": 5,
    "MaxEvidenceItems": 3,
    "MaxContextCharacters": 4800,
    "MaxOutputTokens": 500
  },
  "SuperChat": {
    "BaseUrl": "https://localhost:8080",
    "AllowedEmails": [
      "pilot@example.com"
    ],
    "MagicLinkMinutes": 15,
    "DevSeedSampleData": true,
    "ApiSessionDays": 30,
    "EnableGroupIngestion": false,
    "MaxIngestedGroupMembers": 30,
    "TodayTimeZoneId": "Europe/Moscow"
  },
  "DeepSeek": {
    "BaseUrl": "https://api.deepseek.com",
    "ApiKey": "",
    "Model": "deepseek-chat"
  },
  "Qdrant": {
    "BaseUrl": "http://localhost:6333",
    "ApiKey": "",
    "AutoInitialize": false,
    "MemoryCollectionName": "memory_bgem3_v1",
    "DenseVectorName": "text-dense",
    "SparseVectorName": "text-sparse",
    "DenseVectorSize": 1024
  },
  "Embedding": {
    "Enabled": true,
    "BaseUrl": "http://localhost:7291",
    "TimeoutSeconds": 60,
    "DenseVectorSize": 1024
  },
  "Matrix": {
    "HomeserverUrl": "https://matrix.localhost",
    "AdminAccessToken": "",
    "UserIdPrefix": "superchat"
  },
  "TelegramBridge": {
    "BotUserId": "@telegrambot:matrix.localhost",
    "WebLoginBaseUrl": "https://bridge.localhost/public",
    "ParticipantCountBaseUrl": "http://mautrix-telegram-helper:29318"
  },
  "Email": {
    "FromSender": "Super Chat <hello@superchat.local>",
    "SmtpHost": "localhost",
    "SmtpPort": 1025
  }
}
