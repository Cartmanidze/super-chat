@page "/settings/connections"
@model SuperChat.Web.Pages.Settings.ConnectionsModel
@{
  ViewData["Title"] = T["Connections.PageTitle"];
}

<section class="stack">
  <div class="section-card">
    <p class="eyebrow">@T["Settings.Eyebrow"]</p>
    <h1>@T["Connections.Title"]</h1>

    <dl class="definition-grid">
      <div>
        <dt>@T["Connections.ProductEmail"]</dt>
        <dd>@Model.Email</dd>
      </div>
      <div>
        <dt>@T["Connections.MatrixUser"]</dt>
        <dd>@(Model.MatrixUserId ?? T["Common.Pending"])</dd>
      </div>
      <div>
        <dt>@T["Connections.TelegramState"]</dt>
        <dd>@UiText.ConnectionState(Model.ConnectionState.ToString())</dd>
      </div>
      <div>
        <dt>@T["Common.LastSync"]</dt>
        <dd>@(Model.LastSyncedAt?.ToString("u") ?? T["Common.Waiting"])</dd>
      </div>
    </dl>

    <form method="post" asp-page-handler="Disconnect" class="hero-actions">
      <button type="submit" class="button primary">@T["Connections.DisconnectTelegram"]</button>
      <a class="button secondary" asp-page="/Connect/Telegram">@T["Connections.BackToConnectFlow"]</a>
    </form>
  </div>
</section>
