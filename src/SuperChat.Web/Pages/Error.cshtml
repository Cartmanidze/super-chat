@page
@model ErrorModel
@{
    ViewData["Title"] = T["Error.PageTitle"];
}

<h1 class="text-danger">@T["Error.Title"]</h1>
<h2 class="text-danger">@T["Error.Subtitle"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@T["Error.RequestId"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@T["Error.DevelopmentModeTitle"]</h3>
<p>@T["Error.DevelopmentModeDescription"]</p>
<p>@T["Error.DevelopmentModeWarning"]</p>
