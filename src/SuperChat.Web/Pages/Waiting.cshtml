@page "/waiting"
@model SuperChat.Web.Pages.WaitingModel
@{
  ViewData["Title"] = T["Waiting.PageTitle"];
}

<section class="stack">
  <div class="section-head">
    <p class="eyebrow">@T["Waiting.Eyebrow"]</p>
    <h1>@T["Waiting.Title"]</h1>
  </div>

  @if (Model.Cards.Count == 0)
  {
    <div class="empty-state">
      <p>@T["Waiting.Empty"]</p>
    </div>
  }
  else
  {
    <div class="stack">
      @foreach (var card in Model.Cards)
      {
        <article class="section-card">
          <span class="pill">@UiText.Kind(card.Kind)</span>
          <h2>@UiText.CardTitle(card.Title)</h2>
          <p>@card.Summary</p>
          <small>@UiText.SourceRoom(card.SourceRoom)</small>
        </article>
      }
    </div>
  }

  @if (Model.RecentResolvedItems.Count > 0)
  {
    <div class="stack">
      <div class="section-head">
        <h2>Недавно закрыто автоматически</h2>
        <p>Сигналы, которые уже не требуют ответа, но которые полезно быстро сверить.</p>
      </div>

      @foreach (var card in Model.RecentResolvedItems)
      {
        <article class="section-card">
          <span class="pill">Авто-резолв</span>
          <h2>@UiText.CardTitle(card.Title)</h2>
          <p>@card.Summary</p>
          <small>@card.ResolutionNote · @card.ResolvedAt.ToLocalTime().ToString("dd.MM, HH:mm")</small>
        </article>
      }
    </div>
  }
</section>
