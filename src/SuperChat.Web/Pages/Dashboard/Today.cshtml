@page "/today"
@model SuperChat.Web.Pages.Dashboard.TodayModel
@{
  ViewData["Title"] = T["Today.PageTitle"];
}

<section class="stack">
  <div class="section-head">
    <p class="eyebrow">@T["Today.Eyebrow"]</p>
    <h1>@T["Today.Title"]</h1>
  </div>

  @if (Model.Cards.Count == 0)
  {
    <div class="empty-state">
      <p>@T["Today.Empty"]</p>
      <a class="button primary" asp-page="/Connect/Telegram">@T["Today.OpenTelegramConnection"]</a>
    </div>
  }
  else
  {
    <div class="card-grid">
      @foreach (var card in Model.Cards)
      {
        <article class="section-card">
          <span class="pill">@UiText.Kind(card.Kind)</span>
          <h2>@UiText.CardTitle(card.Title)</h2>
          <p>@card.Summary</p>
          <small>@UiText.SourceRoom(card.SourceRoom)</small>
        </article>
      }
    </div>
  }
</section>
