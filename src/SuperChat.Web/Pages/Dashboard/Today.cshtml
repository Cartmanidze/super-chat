@page "/today"
@model SuperChat.Web.Pages.Dashboard.TodayModel
@{
  ViewData["Title"] = "Today";
}

<section class="stack">
  <div class="section-head">
    <p class="eyebrow">Digest</p>
    <h1>Today matters</h1>
  </div>

  @if (Model.Cards.Count == 0)
  {
    <div class="empty-state">
      <p>No cards yet. Connect Telegram and let the bootstrap sync/extraction cycle seed the first digest.</p>
      <a class="button primary" asp-page="/Connect/Telegram">Open Telegram connection</a>
    </div>
  }
  else
  {
    <div class="card-grid">
      @foreach (var card in Model.Cards)
      {
        <article class="section-card">
          <span class="pill">@card.Kind</span>
          <h2>@card.Title</h2>
          <p>@card.Summary</p>
          <small>@card.SourceRoom</small>
        </article>
      }
    </div>
  }
</section>
