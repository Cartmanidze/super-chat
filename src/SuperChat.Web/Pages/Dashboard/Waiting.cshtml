@page "/waiting"
@model SuperChat.Web.Pages.Dashboard.WaitingModel
@{
  ViewData["Title"] = "Waiting";
}

<section class="stack">
  <div class="section-head">
    <p class="eyebrow">Follow-up</p>
    <h1>Waiting for reply</h1>
  </div>

  @if (Model.Cards.Count == 0)
  {
    <div class="empty-state">
      <p>No active waiting-on items yet.</p>
    </div>
  }
  else
  {
    <div class="stack">
      @foreach (var card in Model.Cards)
      {
        <article class="section-card">
          <span class="pill">@card.Kind</span>
          <h2>@card.Title</h2>
          <p>@card.Summary</p>
          <small>@card.SourceRoom</small>
        </article>
      }
    </div>
  }
</section>
