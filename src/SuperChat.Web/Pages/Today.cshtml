@page "/today"
@model SuperChat.Web.Pages.TodayModel
@{
  ViewData["Title"] = T["Today.PageTitle"];
  var activeLane = Model.ActiveSection;
}

<section class="page-stack">
  <div class="page-hero insight-hero">
    <div class="page-hero-copy">
      <p class="section-kicker">@T["Today.Eyebrow"]</p>
      <h1>@T["Today.Title"]</h1>
      <p class="page-intro">
        В этой панели за 20 секунд должно быть понятно, где нужен ответ, что уже обещано, какие встречи приближаются
        и какие сигналы реально важны сегодня.
      </p>
    </div>

    <div class="metric-grid">
      <article class="metric-card">
        <span class="metric-label">Нужно ответить</span>
        <strong>@Model.Summary.WaitingCount</strong>
        <small>живых точек внимания</small>
      </article>
      <article class="metric-card">
        <span class="metric-label">Ты пообещал</span>
        <strong>@Model.Summary.CommitmentCount</strong>
        <small>зафиксированных обещаний</small>
      </article>
      <article class="metric-card">
        <span class="metric-label">Скоро встречи</span>
        <strong>@Model.Summary.MeetingCount</strong>
        <small>временных договоренностей</small>
      </article>
      <article class="metric-card">
        <span class="metric-label">Важно сегодня</span>
        <strong>@Model.Summary.TodayCount</strong>
        <small>сигналов в фокусе</small>
      </article>
    </div>
  </div>

  @if (!Model.TelegramConnected)
  {
    <section class="empty-shell">
      <div class="empty-card">
        <span class="status-badge status-warning">Telegram не подключен</span>
        <h2>Сначала подключите Telegram</h2>
        <p>
          SuperChat начинает работать только после подключения Telegram. После этого появятся сигналы по обещаниям,
          follow-up'ам, встречам и важным темам дня.
        </p>
        <div class="inline-actions">
          <a class="app-button app-button-primary" asp-page="/Connect/Telegram">Подключить Telegram</a>
          <a class="app-button app-button-secondary" asp-page="/Search/Index">Открыть поиск</a>
        </div>
      </div>
    </section>
  }
  else
  {
    <section class="focus-stack">
      <form method="get" class="section-switcher" aria-label="Тип сигнала">
        @foreach (var laneOption in Model.Sections)
        {
          var isActive = string.Equals(laneOption.Id, Model.SelectedSectionId, StringComparison.OrdinalIgnoreCase);
          <button type="submit"
                  class="section-switcher-item@(isActive ? " is-active" : string.Empty)"
                  name="section"
                  value="@laneOption.Id"
                  aria-pressed="@(isActive ? "true" : "false")">
            <span>@laneOption.Title</span>
            <strong>@laneOption.Items.Count</strong>
          </button>
        }
      </form>

      <article class="focus-lane">
        <header class="lane-header lane-header-focus">
          <div>
            <h2>@activeLane.Title</h2>
            <p>@activeLane.Description</p>
          </div>
          <span class="count-pill">@activeLane.Items.Count</span>
        </header>

        @if (activeLane.Items.Count == 0)
        {
          <div class="lane-empty">
            <p>@activeLane.EmptyText</p>
          </div>
        }
        else
        {
          <div class="signal-list signal-list-focus">
            @foreach (var card in activeLane.Items)
            {
              <article class="signal-card signal-card-focus">
                <div class="signal-head">
                  <span class="signal-kind">@activeLane.Title</span>
                  <div class="signal-badges">
                    <span class="signal-confidence">@card.ConfidencePercent%</span>
                    <span class="signal-hint">@card.Hint</span>
                  </div>
                </div>

                <h3>@UiText.CardTitle(card.Title)</h3>
                <p class="signal-summary">@card.Summary</p>

                <div class="signal-meta">
                  <span>@UiText.SourceRoom(card.ChatLabel)</span>
                  <span>@card.Timestamp.ToLocalTime().ToString("dd.MM, HH:mm")</span>
                </div>

                <div class="signal-actions">
                  <a class="action-link" asp-page="/Search/Index" asp-route-query="@card.SearchQuery">Открыть</a>
                  @if (card.SupportsActions)
                  {
                    <form method="post" asp-page-handler="Complete" class="action-form">
                      <input type="hidden" name="id" value="@card.Id" />
                      <input type="hidden" name="type" value="@card.Type" />
                      <input type="hidden" name="section" value="@activeLane.Id" />
                      <button type="submit" class="action-link">Готово</button>
                    </form>
                    <form method="post" asp-page-handler="Dismiss" class="action-form">
                      <input type="hidden" name="id" value="@card.Id" />
                      <input type="hidden" name="type" value="@card.Type" />
                      <input type="hidden" name="section" value="@activeLane.Id" />
                      <button type="submit" class="action-link">Скрыть</button>
                    </form>
                  }
                </div>
                <div class="signal-feedback">
                  <a class="signal-feedback-link" asp-page="/Feedback/Index">Не полезно</a>
                </div>
              </article>
            }
          </div>
        }
      </article>
    </section>
  }
</section>
