@page "/today"
@model SuperChat.Web.Pages.TodayModel
@{
  ViewData["Title"] = T["Today.PageTitle"];
  var meetings = Model.MeetingsSection;
}

<section class="page-stack">
  <div class="page-hero insight-hero">
    <div class="page-hero-copy">
      <p class="section-kicker">@T["Today.Eyebrow"]</p>
      <h1>@T["Today.Meetings.Title"]</h1>
      <p class="page-intro">@T["Today.Meetings.Intro"]</p>
    </div>

    <div class="metric-grid">
      <article class="metric-card">
        <span class="metric-label">@T["Today.Meetings.Metric.Label"]</span>
        <strong>@Model.Summary.MeetingCount</strong>
        <small>@T["Today.Meetings.Metric.Copy"]</small>
      </article>
    </div>
  </div>

  @if (!Model.TelegramConnected)
  {
    <section class="empty-shell">
      <div class="empty-card">
        <span class="status-badge status-warning">@T["Today.Connection.Warning"]</span>
        <h2>@T["Today.Connection.Title"]</h2>
        <p>@T["Today.Connection.Copy"]</p>
        <div class="inline-actions">
          <a class="app-button app-button-primary" asp-page="/Connect/Telegram">@T["Chat.ConnectTelegram"]</a>
          <a class="app-button app-button-secondary" asp-page="/Search/Index">@T["Today.Connection.SearchAction"]</a>
        </div>
      </div>
    </section>
  }
  else
  {
    <section class="focus-stack">
      <article class="focus-lane">
        <header class="lane-header lane-header-focus">
          <div>
            <h2>@meetings.Title</h2>
            <p>@meetings.Description</p>
          </div>
          <span class="count-pill">@meetings.Items.Count</span>
        </header>

        @if (meetings.Items.Count == 0)
        {
          <div class="lane-empty">
            <p>@meetings.EmptyText</p>
          </div>
        }
        else
        {
          <div class="signal-list signal-list-focus">
            @foreach (var card in meetings.Items)
            {
              <article class="signal-card signal-card-focus">
                <div class="signal-head">
                  <span class="signal-kind">@T["Kind.Meeting"]</span>
                  <div class="signal-badges">
                    <span class="signal-confidence">@card.ConfidencePercent%</span>
                    <span class="signal-hint">@card.Hint</span>
                  </div>
                </div>

                <h3>@UiText.CardTitle(card.Title)</h3>
                <p class="signal-summary">@card.Summary</p>

                <div class="signal-meta">
                  <span>@UiText.SourceRoom(card.ChatLabel)</span>
                  <span>@card.Timestamp.ToLocalTime().ToString("dd.MM, HH:mm")</span>
                </div>

                <div class="signal-actions">
                  <a class="action-link" asp-page="/Search/Index" asp-route-query="@card.SearchQuery">@T["Today.Actions.Open"]</a>
                  @if (card.SupportsActions)
                  {
                    <form method="post" asp-page-handler="Complete" class="action-form">
                      <input type="hidden" name="id" value="@card.Id" />
                      <button type="submit" class="action-link">@T["Today.Actions.Complete"]</button>
                    </form>
                    <form method="post" asp-page-handler="Dismiss" class="action-form">
                      <input type="hidden" name="id" value="@card.Id" />
                      <button type="submit" class="action-link">@T["Today.Actions.Dismiss"]</button>
                    </form>
                  }
                </div>
                <div class="signal-feedback">
                  <a class="signal-feedback-link" asp-page="/Feedback/Index">@T["Feedback.Useful.No"]</a>
                </div>
              </article>
            }
          </div>
        }
      </article>
    </section>
  }
</section>
