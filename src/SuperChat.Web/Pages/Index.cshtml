@page
@using System.Text.Json
@model IndexModel
@{
  ViewData["Title"] = T["Search.PageTitle"];
  var templates = Model.Templates;
  var defaultTemplate = Model.DefaultTemplate;
  var defaultQuestion = T[defaultTemplate.QuestionKey].Value;
  var clientStrings = JsonSerializer.Serialize(new
  {
    genericError = T["Chat.Error.Generic"].Value,
    thinking = T["Chat.Thinking"].Value,
    answerPlaceholder = T["Chat.Ui.AnswerPlaceholder"].Value,
    answerFallback = T["Chat.Ui.AnswerFallback"].Value,
    errorTitle = T["Chat.Ui.ErrorTitle"].Value,
    evidenceEmptyTitle = T["Chat.Ui.EvidenceEmptyTitle"].Value,
    evidenceEmpty = T["Chat.Ui.EvidenceEmpty"].Value,
    contextTitle = T["Chat.Ui.ContextTitle"].Value,
    contextBody = T["Chat.Ui.ContextBody"].Value,
    sourceLabel = T["Chat.Answer.Source"].Value,
    signalLabel = T["Chat.Ui.SignalLabel"].Value,
    openLabel = T["Chat.Ui.OpenLabel"].Value,
    feedbackLabel = T["Feedback.Useful.No"].Value
  });
}

@if (!Model.IsSignedIn)
{
  <section class="landing-grid">
    <div class="landing-copy">
      <p class="section-kicker">SuperChat</p>
      <h1>@T["Landing.Title"]</h1>
      <p class="landing-lead">@T["Landing.Lead"]</p>

      <div class="landing-points">
        <article class="landing-point">
          <strong>@T["Landing.Point.Meetings.Title"]</strong>
          <span>@T["Landing.Point.Meetings.Copy"]</span>
        </article>
        <article class="landing-point">
          <strong>@T["Landing.Point.AutoRefresh.Title"]</strong>
          <span>@T["Landing.Point.AutoRefresh.Copy"]</span>
        </article>
        <article class="landing-point">
          <strong>@T["Landing.Point.Context.Title"]</strong>
          <span>@T["Landing.Point.Context.Copy"]</span>
        </article>
        <article class="landing-point">
          <strong>@T["Landing.Point.Focus.Title"]</strong>
          <span>@T["Landing.Point.Focus.Copy"]</span>
        </article>
      </div>
    </div>

    <div class="login-panel">
      <div class="login-card premium-card">
        <p class="section-kicker">@T["Chat.Auth.Kicker"]</p>
        <h2>@T["Landing.Login.Title"]</h2>
        <p class="support-copy">@T["Landing.Login.Copy"]</p>

        <form method="post" asp-page-handler="RequestLink" class="auth-form">
          <label asp-for="Email" class="visually-hidden">@T["Common.Email"]</label>
          <input asp-for="Email" type="email" placeholder="@T["Home.PilotEmailPlaceholder"]" autocomplete="email" />
          <button type="submit" class="app-button app-button-primary app-button-block">@T["Auth.RequestLink.Send"]</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
          <div class="inline-alert inline-alert-info">
            @Model.StatusMessage
          </div>
        }

        @if (Model.CodeSent)
        {
          <div class="inline-alert">
            <a class="inline-link" asp-page="/Auth/Verify" asp-route-email="@Model.Email">@T["Auth.RequestLink.EnterCode"]</a>
          </div>
        }

        <div class="support-note">
          <span class="status-badge status-neutral">Invite-only</span>
          <p>@T["Landing.InviteOnly"]</p>
        </div>
      </div>
    </div>
  </section>
}
else
{
  <section class="page-stack">
    <div class="page-hero search-hero">
      <div class="page-hero-copy">
        <p class="section-kicker">@T["Search.Eyebrow"]</p>
        <h1>@T["Search.Chat.Title"]</h1>
        <p class="page-intro">@T["Search.Chat.Intro"]</p>
      </div>

      <div class="hero-action-stack">
        <a class="app-button app-button-secondary" asp-page="/Today">@T["Search.Chat.MeetingsAction"]</a>
        <a class="app-button app-button-ghost" asp-page="/Search/Index">@T["Search.Chat.SearchAction"]</a>
      </div>
    </div>

    @if (!Model.CanAskQuestions)
    {
      <section class="empty-shell">
        <div class="empty-card">
          <span class="status-badge status-warning">@T["Search.Connection.Warning"]</span>
          <h2>@T["Search.Connection.Title"]</h2>
          <p>@T["Search.Connection.Copy"]</p>
          <div class="inline-actions">
            <a class="app-button app-button-primary" asp-page="/Connect/Telegram">@T["Chat.ConnectTelegram"]</a>
            <a class="app-button app-button-secondary" asp-page="/Settings/Connections">@T["Search.Connection.SettingsAction"]</a>
          </div>
        </div>
      </section>
    }
    else
    {
      <section class="ask-layout">
        <div class="ask-main">
          <div class="premium-card query-studio">
            <div class="query-header">
              <div>
                <p class="section-kicker">@T["Search.Query.Kicker"]</p>
                <h2>@T["Search.Query.Title"]</h2>
              </div>
              <span class="status-badge status-success">@T["Search.Query.Status"]</span>
            </div>

            <div class="chip-grid" role="radiogroup" aria-label="@T["Chat.Templates.Label"]">
              @foreach (var template in templates)
              {
                var isDefaultTemplate = string.Equals(template.Id, defaultTemplate.Id, StringComparison.OrdinalIgnoreCase);
                <button type="button"
                        class="prompt-chip@(isDefaultTemplate ? " is-selected" : string.Empty)"
                        data-template-id="@template.Id"
                        data-template-question="@T[template.QuestionKey]"
                        data-template-title="@T[template.TitleKey]"
                        data-template-description="@T[template.DescriptionKey]"
                        aria-pressed="@(isDefaultTemplate ? "true" : "false")">
                  <strong>@T[template.TitleKey]</strong>
                  <span>@T[template.DescriptionKey]</span>
                </button>
              }
            </div>

            <form id="chat-form" method="post" asp-page-handler="Ask" class="query-form">
              @Html.AntiForgeryToken()
              <input asp-for="TemplateId" type="hidden" value="@defaultTemplate.Id" />

              <label asp-for="Question" class="form-label">@T["Chat.Input.Label"]</label>
              <div class="query-input-shell">
                <textarea asp-for="Question"
                          id="chat-question"
                          rows="3"
                          maxlength="@Model.MaxQuestionLength"
                          readonly>@defaultQuestion</textarea>
                <div class="query-meta">
                  <p id="composer-hint" class="query-hint">@T[defaultTemplate.DescriptionKey]</p>
                  <div class="query-actions">
                    <span class="character-counter"><span id="char-count">@defaultQuestion.Length</span>/@Model.MaxQuestionLength</span>
                    <button id="chat-send" type="submit" class="app-button app-button-primary">@T["Chat.Send"]</button>
                  </div>
                </div>
              </div>
            </form>
          </div>

          <div class="answer-layout">
            <section class="answer-column">
              <article id="answer-summary" class="premium-card answer-card is-empty">
                <p class="section-kicker">@T["Chat.Ui.AnswerKicker"]</p>
                <h2>@T["Chat.Ui.AnswerTitle"]</h2>
                <p id="answer-copy">@T["Chat.Ui.AnswerPlaceholder"]</p>
              </article>

              <section class="premium-card evidence-section">
                <div class="section-headline">
                  <div>
                    <p class="section-kicker">@T["Chat.Ui.EvidenceKicker"]</p>
                    <h2>@T["Chat.Ui.EvidenceTitle"]</h2>
                  </div>
                  <a class="inline-link" asp-page="/Search/Index">@T["Search.Chat.SearchAction"]</a>
                </div>

                <div id="evidence-list" class="evidence-list">
                  <article class="evidence-card evidence-card-placeholder">
                    <strong>@T["Chat.Ui.EvidenceEmptyTitle"]</strong>
                    <p>@T["Chat.Ui.EvidenceEmpty"]</p>
                  </article>
                </div>
              </section>
            </section>

            <aside id="context-panel" class="premium-card context-panel">
              <p class="section-kicker">@T["Chat.Ui.ContextKicker"]</p>
              <h2 id="context-title">@T["Chat.Ui.ContextTitle"]</h2>
              <p id="context-copy">@T["Chat.Ui.ContextBody"]</p>
              <dl class="context-meta">
                <div>
                  <dt>@T["Chat.Answer.Source"]</dt>
                  <dd id="context-source">-</dd>
                </div>
                <div>
                  <dt>@T["Chat.Ui.TimeLabel"]</dt>
                  <dd id="context-time">-</dd>
                </div>
              </dl>
              <div class="context-actions">
                <a id="context-open" class="app-button app-button-secondary" asp-page="/Search/Index">@T["Chat.Ui.OpenLabel"]</a>
                <a class="app-button app-button-ghost" asp-page="/Feedback/Index">@T["Feedback.Useful.No"]</a>
              </div>
            </aside>
          </div>
        </div>
      </section>
    }
  </section>

  @section Scripts
  {
    <script>
      (function () {
        var strings = @Html.Raw(clientStrings);
        var form = document.getElementById("chat-form");
        if (!form) {
          return;
        }

        var buttons = Array.prototype.slice.call(document.querySelectorAll(".prompt-chip"));
        var templateInput = document.getElementById("TemplateId");
        var questionInput = document.getElementById("chat-question");
        var charCount = document.getElementById("char-count");
        var hint = document.getElementById("composer-hint");
        var sendButton = document.getElementById("chat-send");
        var answerSummary = document.getElementById("answer-summary");
        var answerCopy = document.getElementById("answer-copy");
        var evidenceList = document.getElementById("evidence-list");
        var contextTitle = document.getElementById("context-title");
        var contextCopy = document.getElementById("context-copy");
        var contextSource = document.getElementById("context-source");
        var contextTime = document.getElementById("context-time");
        var contextOpen = document.getElementById("context-open");
        var maxLength = @Model.MaxQuestionLength;
        var defaultTemplateId = "@defaultTemplate.Id";

        function updateCounter() {
          charCount.textContent = String(questionInput.value.length);
        }

        function updateSubmitState() {
          sendButton.disabled = questionInput.value.trim().length === 0 || questionInput.value.length > maxLength;
        }

        function setActiveTemplate(button) {
          buttons.forEach(function (item) {
            var active = item === button;
            item.classList.toggle("is-selected", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });

          templateInput.value = button.dataset.templateId || defaultTemplateId;
          hint.textContent = button.dataset.templateDescription || "";
          questionInput.value = button.dataset.templateQuestion || "";
          updateCounter();
          updateSubmitState();
        }

        function resetContextPanel() {
          contextTitle.textContent = strings.contextTitle;
          contextCopy.textContent = strings.contextBody;
          contextSource.textContent = "-";
          contextTime.textContent = "-";
          contextOpen.setAttribute("href", "/search");
        }

        function selectEvidence(card) {
          var cards = evidenceList.querySelectorAll(".evidence-card");
          cards.forEach(function (item) { item.classList.remove("is-selected"); });
          card.classList.add("is-selected");

          contextTitle.textContent = card.dataset.title || "";
          contextCopy.textContent = card.dataset.summary || "";
          contextSource.textContent = card.dataset.source || "-";
          contextTime.textContent = card.dataset.time || "-";
          contextOpen.setAttribute("href", card.dataset.href || "/search");
        }

        function renderEvidence(items) {
          evidenceList.innerHTML = "";

          if (!items || items.length === 0) {
            var emptyCard = document.createElement("article");
            emptyCard.className = "evidence-card evidence-card-placeholder";
            emptyCard.innerHTML = "<strong>" + strings.evidenceEmptyTitle + "</strong><p>" + strings.evidenceEmpty + "</p>";
            evidenceList.appendChild(emptyCard);
            resetContextPanel();
            return;
          }

          items.forEach(function (item, index) {
            var card = document.createElement("article");
            card.className = "evidence-card";
            card.tabIndex = 0;

            var timestampLabel = item.timestamp
              ? new Date(item.timestamp).toLocaleString(document.documentElement.lang || undefined)
              : "-";

            var searchSeed = encodeURIComponent(item.title || item.summary || item.sourceRoom || "");
            card.dataset.title = item.title || "";
            card.dataset.summary = item.summary || "";
            card.dataset.source = item.sourceRoom || "-";
            card.dataset.time = timestampLabel;
            card.dataset.href = "/search?query=" + searchSeed;

            card.innerHTML =
              "<div class=\"evidence-head\">" +
                "<strong>" + (item.title || strings.signalLabel) + "</strong>" +
                "<span>" + timestampLabel + "</span>" +
              "</div>" +
              (item.summary ? "<p>" + item.summary + "</p>" : "") +
              "<small>" + strings.sourceLabel + ": " + (item.sourceRoom || "-") + "</small>";

            card.addEventListener("click", function () { selectEvidence(card); });
            card.addEventListener("keypress", function (event) {
              if (event.key === "Enter" || event.key === " ") {
                event.preventDefault();
                selectEvidence(card);
              }
            });

            evidenceList.appendChild(card);

            if (index === 0) {
              selectEvidence(card);
            }
          });
        }

        function renderLoadingState() {
          answerSummary.classList.remove("is-empty");
          answerSummary.classList.add("is-loading");
          answerCopy.textContent = strings.thinking;
          evidenceList.innerHTML =
            "<article class=\"evidence-card skeleton-card\"></article>" +
            "<article class=\"evidence-card skeleton-card\"></article>";
          resetContextPanel();
        }

        function renderAnswer(payload) {
          answerSummary.classList.remove("is-empty", "is-loading");
          answerCopy.textContent = payload.assistantText && payload.assistantText.trim().length > 0
            ? payload.assistantText
            : strings.answerFallback;

          renderEvidence(payload.items || []);
        }

        buttons.forEach(function (button) {
          button.addEventListener("click", function () {
            setActiveTemplate(button);
          });
        });

        form.addEventListener("submit", async function (event) {
          event.preventDefault();
          updateSubmitState();
          if (sendButton.disabled) {
            return;
          }

          renderLoadingState();
          sendButton.disabled = true;

          try {
            var response = await fetch("?handler=Ask", {
              method: "POST",
              body: new FormData(form),
              credentials: "same-origin"
            });

            if (!response.ok) {
              var errorPayload = await response.json().catch(function () { return null; });
              answerSummary.classList.remove("is-loading");
              answerCopy.textContent = errorPayload && errorPayload.error ? errorPayload.error : strings.genericError;
              evidenceList.innerHTML = "<article class=\"evidence-card evidence-card-placeholder\"><strong>" + strings.errorTitle + "</strong><p>" + strings.genericError + "</p></article>";
              resetContextPanel();
              updateSubmitState();
              return;
            }

            var payload = await response.json();
            renderAnswer(payload);
          } catch (error) {
            answerSummary.classList.remove("is-loading");
            answerCopy.textContent = strings.genericError;
            evidenceList.innerHTML = "<article class=\"evidence-card evidence-card-placeholder\"><strong>" + strings.errorTitle + "</strong><p>" + strings.genericError + "</p></article>";
            resetContextPanel();
          }

          updateCounter();
          updateSubmitState();
        });

        updateCounter();
        updateSubmitState();
        resetContextPanel();
      })();
    </script>
  }
}
