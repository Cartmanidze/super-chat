@page
@model IndexModel
@{
  ViewData["Title"] = "super-chat";
}

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">@T["Home.Eyebrow"]</p>
    <h1>@T["Home.Title"]</h1>
    <p class="lede">@T["Home.Lede"]</p>

    @if (Model.IsSignedIn)
    {
      <div class="hero-actions">
        <a class="button primary" asp-page="/Dashboard/Today">@T["Home.OpenToday"]</a>
        <a class="button secondary" asp-page="/Connect/Telegram">@T["Home.ManageTelegramConnection"]</a>
      </div>
    }
    else
    {
      <form method="post" asp-page="/Auth/RequestLink" class="auth-panel">
        <label asp-for="Email">@T["Home.PilotEmailLabel"]</label>
        <input asp-for="Email" type="email" placeholder="@T["Home.PilotEmailPlaceholder"]" />
        <button type="submit" class="button primary">@T["Home.RequestMagicLink"]</button>
      </form>
      <p class="hint">@T["Home.InviteOnlyHint"]</p>
    }
  </div>

  <div class="hero-rail">
    <div class="metric-card">
      <span>@T["Home.Metric.Milestone.Label"]</span>
      <strong>@T["Home.Metric.Milestone.Value"]</strong>
    </div>
    <div class="metric-card">
      <span>@T["Home.Metric.Modules.Label"]</span>
      <strong>@T["Home.Metric.Modules.Value"]</strong>
    </div>
    <div class="metric-card">
      <span>@T["Home.Metric.Mode.Label"]</span>
      <strong>@(Model.IsDevelopmentMode ? T["Home.BootstrapMode.Development"] : T["Home.BootstrapMode.Live"])</strong>
    </div>
  </div>
</section>
