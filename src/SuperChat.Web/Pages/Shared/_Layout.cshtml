<!DOCTYPE html>
@{
  var currentPath = $"{Context.Request.PathBase}{Context.Request.Path}";
  var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - super-chat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/SuperChat.Web.styles.css" asp-append-version="true" />
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a class="brand" asp-page="/Index">super-chat</a>
      <nav class="topnav">
        <a asp-page="/Connect/Telegram">@T["Nav.Connect"]</a>
        <a asp-page="/Dashboard/Today">@T["Nav.Today"]</a>
        <a asp-page="/Dashboard/Waiting">@T["Nav.Waiting"]</a>
        <a asp-page="/Search/Index">@T["Nav.Search"]</a>
        <a asp-page="/Feedback/Index">@T["Nav.Feedback"]</a>
        <a asp-page="/Settings/Connections">@T["Nav.Settings"]</a>
        <div class="language-switcher" aria-label="@T["Nav.Language"]">
          @foreach (var culture in AppCultures.Supported)
          {
            var isActive = string.Equals(currentCulture, culture.Name, StringComparison.OrdinalIgnoreCase);
            <a class="culture-link @(isActive ? "active" : null)"
               href="/localization/set-language?culture=@culture.Name&returnUrl=@Uri.EscapeDataString(currentPath)">
              @culture.ShortName
            </a>
          }
        </div>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
          <form method="post" asp-page="/Auth/SignOut" class="inline-form">
            <button type="submit" class="nav-button">@T["Nav.SignOut"]</button>
          </form>
        }
      </nav>
    </header>

    <main class="page-body">
      @RenderBody()
    </main>
  </div>

  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
