@page "/auth/verify"
@model SuperChat.Web.Pages.Auth.VerifyModel
@{
  ViewData["Title"] = T["Auth.Verify.PageTitle"];
}

<section class="auth-screen">
  <div class="auth-card">
    <h1>@T["Auth.Verify.Title"]</h1>
    <p class="auth-copy">@Model.StatusMessage</p>

    @if (!Model.Success)
    {
      <form method="post" class="auth-form">
        <input type="hidden" asp-for="Email" />
        <label asp-for="Code" class="visually-hidden">@T["Auth.Verify.CodeLabel"]</label>
        <input asp-for="Code"
               type="text"
               inputmode="numeric"
               pattern="[0-9]{6}"
               maxlength="6"
               autocomplete="one-time-code"
               placeholder="000000"
               class="code-input" />
        <button type="submit" class="send-button wide">@T["Auth.Verify.Submit"]</button>
      </form>

      <a class="inline-link" asp-page="/Auth/RequestLink">@T["Auth.Verify.RequestAnotherCode"]</a>
    }
  </div>
</section>
