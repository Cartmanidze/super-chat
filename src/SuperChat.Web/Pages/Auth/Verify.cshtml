@page "/auth/verify"
@model SuperChat.Web.Pages.Auth.VerifyModel
@{
  ViewData["Title"] = T["Auth.Verify.PageTitle"];
}

<section class="auth-screen">
  <div class="auth-card">
    <h1>@T["Auth.Verify.Title"]</h1>
    <p class="auth-copy">@Model.StatusMessage</p>

    @if (!Model.Success)
    {
      <a class="inline-link" asp-page="/Auth/RequestLink">@T["Auth.Verify.RequestAnotherLink"]</a>
    }
  </div>
</section>
