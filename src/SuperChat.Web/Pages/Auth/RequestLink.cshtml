@page "/auth/request-link"
@model SuperChat.Web.Pages.Auth.RequestLinkModel
@{
  ViewData["Title"] = T["Auth.RequestLink.PageTitle"];
}

<section class="stack">
  <div class="section-card">
    <h1>@T["Auth.RequestLink.Title"]</h1>
    <p>@T["Auth.RequestLink.Description"]</p>

    <form method="post" class="stack">
      <div>
        <label asp-for="Email">@T["Common.Email"]</label>
        <input asp-for="Email" type="email" placeholder="@T["Home.PilotEmailPlaceholder"]" />
      </div>
      <button type="submit" class="button primary">@T["Auth.RequestLink.Send"]</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
      <p class="notice">@Model.StatusMessage</p>
    }

    @if (Model.DevelopmentLink is not null)
    {
      <div class="dev-link">
        <p>@T["Auth.RequestLink.DevelopmentShortcut"]</p>
        <a href="@Model.DevelopmentLink">@Model.DevelopmentLink</a>
      </div>
    }
  </div>
</section>
