@page "/auth/request-link"
@model SuperChat.Web.Pages.Auth.RequestLinkModel
@{
  ViewData["Title"] = T["Auth.RequestLink.PageTitle"];
}

<section class="auth-screen">
  <div class="auth-card">
    <p class="auth-kicker">@T["Chat.Auth.Kicker"]</p>
    <h1>@T["Auth.RequestLink.Title"]</h1>
    <p class="auth-copy">@T["Auth.RequestLink.Description"]</p>

    @if (!Model.CodeSent)
    {
      <form method="post" class="auth-form">
        <label asp-for="Email" class="visually-hidden">@T["Common.Email"]</label>
        <input asp-for="Email" type="email" placeholder="@T["Home.PilotEmailPlaceholder"]" autocomplete="email" />
        <button type="submit" class="send-button wide">@T["Auth.RequestLink.Send"]</button>
      </form>
    }
    else
    {
      <p class="status-note">@Model.StatusMessage</p>
      <a class="inline-link" asp-page="/Auth/Verify" asp-route-email="@Model.Email">@T["Auth.RequestLink.EnterCode"]</a>
    }

    @if (!Model.CodeSent && !string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
      <p class="status-note">@Model.StatusMessage</p>
    }
  </div>
</section>
