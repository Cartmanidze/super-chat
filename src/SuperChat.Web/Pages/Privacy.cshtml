@page "/privacy"
@model SuperChat.Web.Pages.PrivacyModel
@{
  ViewData["Title"] = "Privacy";
}

<section class="section-card">
  <p class="eyebrow">Privacy</p>
  <h1>Bootstrap privacy notes</h1>
  <ul class="stack">
    <li>Access is limited to invited pilot users.</li>
    <li>The bootstrap keeps Matrix and Telegram integration behind the product UI.</li>
    <li>Extracted items are intended for Today, Waiting, Search, and pilot feedback loops only.</li>
    <li>Public launch should stay blocked until Telegram terms are reviewed separately.</li>
  </ul>
</section>
