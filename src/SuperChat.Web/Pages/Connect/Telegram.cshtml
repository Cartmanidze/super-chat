@page "/connect/telegram"
@using SuperChat.Domain.Features.Integrations
@model SuperChat.Web.Pages.Connect.TelegramModel
@{
  ViewData["Title"] = T["ConnectTelegram.PageTitle"];
  var state = Model.Connection.State;
  var connected = state == IntegrationConnectionState.Connected;
  var pending = state == IntegrationConnectionState.Pending;
  var error = state == IntegrationConnectionState.Error;
  var requiresSetup = state == IntegrationConnectionState.RequiresSetup;
  var hasActionUrl = Model.Connection.ActionUrl is not null;
  var canReconnect = connected || error || pending;
}

<section class="page-stack">
  <div class="page-hero">
    <div class="page-hero-copy">
      <p class="section-kicker">@T["ConnectTelegram.Eyebrow"]</p>
      <h1>Подключение Telegram</h1>
      <p class="page-intro">
        Подключение происходит изнутри SuperChat. После этого продукт начнёт собирать обещания, follow-up'ы,
        встречи и важные сигналы прямо из ваших рабочих переписок.
      </p>
    </div>
    <span class="status-badge @(connected ? "status-success" : pending ? "status-warning" : error ? "status-danger" : "status-neutral")">
      @UiText.ConnectionState(state.ToString())
    </span>
  </div>

  <div class="split-panel">
    <section class="premium-card connection-panel">
      <div class="section-headline">
        <div>
          <p class="section-kicker">Статус подключения</p>
          <h2>@(connected ? "Telegram подключён" : pending ? "Ожидание подключения" : error ? "Ошибка подключения" : "Подключите Telegram")</h2>
        </div>
      </div>

      <dl class="detail-grid">
        <div class="detail-row">
          <dt>@T["ConnectTelegram.MatrixUser"]</dt>
          <dd>@(Model.MatrixUserId ?? "Будет создан автоматически")</dd>
        </div>
        <div class="detail-row">
          <dt>@T["Common.Status"]</dt>
          <dd>@UiText.ConnectionState(state.ToString())</dd>
        </div>
        <div class="detail-row">
          <dt>@T["Common.LastSync"]</dt>
          <dd>@(Model.Connection.LastSyncedAt?.ToLocalTime().ToString("dd.MM.yyyy, HH:mm") ?? "Ещё не синхронизировано")</dd>
        </div>
      </dl>

      <div class="feature-stack">
        <article class="feature-chip-card">
          <strong>Обещания</strong>
          <span>Кому и что вы пообещали в переписках.</span>
        </article>
        <article class="feature-chip-card">
          <strong>Follow-ups</strong>
          <span>Где от вас ждут ответ или следующий шаг.</span>
        </article>
        <article class="feature-chip-card">
          <strong>Встречи</strong>
          <span>Временные договорённости и ближайшие созвоны.</span>
        </article>
        <article class="feature-chip-card">
          <strong>Важные сигналы</strong>
          <span>Смысловые куски, которые стоит поднять на поверхность.</span>
        </article>
      </div>

      @if (hasActionUrl)
      {
        <div class="inline-alert inline-alert-info">
          <strong>Следующий шаг.</strong>
          <span>Откройте ссылку ниже для входа через Telegram bridge:</span>
          <a class="inline-link" href="@Model.Connection.ActionUrl" target="_blank" rel="noopener">Открыть Telegram Login</a>
        </div>
      }
      else if (pending)
      {
        <div class="inline-alert inline-alert-info">
          Bridge готовит ссылку для входа. Страница обновится автоматически.
        </div>
      }
      else if (error)
      {
        <div class="inline-alert inline-alert-error">
          Произошла ошибка при подключении. Попробуйте переподключиться.
        </div>
      }
      else if (requiresSetup)
      {
        <div class="inline-alert inline-alert-info">
          Требуется настройка Matrix-аккаунта. Обратитесь к администратору.
        </div>
      }

      <div class="inline-actions">
        @if (connected)
        {
          <button type="button" class="app-button app-button-primary" data-open-reconnect-confirm>Переподключить Telegram</button>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else if (pending)
        {
          <button type="button" class="app-button app-button-secondary" data-open-reconnect-confirm>Начать заново</button>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else if (error)
        {
          <form method="post" asp-page-handler="Reconnect" style="display:inline">
            <button type="submit" class="app-button app-button-primary">Повторить подключение</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else
        {
          <form method="post" style="display:inline">
            <button type="submit" class="app-button app-button-primary">Подключить Telegram</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
      </div>
    </section>

    <aside class="premium-card connection-aside">
      <p class="section-kicker">Как это работает</p>
      <h2>Три шага подключения</h2>
      <ol class="timeline-list">
        <li>
          <strong>1. Запуск</strong>
          <span>Нажмите кнопку — SuperChat создаст безопасное соединение с bridge.</span>
        </li>
        <li>
          <strong>2. Вход в Telegram</strong>
          <span>Появится ссылка для входа: номер, код, 2FA (если включён).</span>
        </li>
        <li>
          <strong>3. Готово</strong>
          <span>Сообщения начнут поступать. Загляните в Today через пару минут.</span>
        </li>
      </ol>

      <div class="privacy-note">
        <strong>Важно.</strong>
        <p>SuperChat не заменяет Telegram. Он строит поверх него слой рабочей памяти и объяснимых сигналов.</p>
      </div>
    </aside>
  </div>
</section>

<dialog id="reconnect-confirm-dialog" class="app-dialog">
  <div class="dialog-shell">
    <div class="dialog-head">
      <div>
        <p class="section-kicker">Подтверждение</p>
        <h2>Переподключить Telegram?</h2>
      </div>
      <button type="button" class="dialog-close" data-close-reconnect-confirm aria-label="Закрыть">x</button>
    </div>

    <div class="dialog-body">
      <p>
        Текущая сессия Telegram bridge будет завершена и запущена заново.
        Вам потребуется повторно пройти вход через Telegram.
      </p>
      @if (connected)
      {
        <p>Входящие сообщения не будут теряться — они продолжат копиться в Telegram и подтянутся после переподключения.</p>
      }
    </div>

    <div class="dialog-actions">
      <form method="post" asp-page-handler="Reconnect" style="display:inline">
        <button type="submit" class="app-button app-button-primary">Да, переподключить</button>
      </form>
      <button type="button" class="app-button app-button-secondary" data-close-reconnect-confirm>Отмена</button>
    </div>
  </div>
</dialog>

@section Scripts
{
  <script>
    (function () {
      var dialog = document.getElementById("reconnect-confirm-dialog");
      if (!dialog || !dialog.showModal) return;

      document.querySelectorAll("[data-open-reconnect-confirm]").forEach(function (btn) {
        btn.addEventListener("click", function () { dialog.showModal(); });
      });
      document.querySelectorAll("[data-close-reconnect-confirm]").forEach(function (btn) {
        btn.addEventListener("click", function () { dialog.close(); });
      });

      @if (pending && !hasActionUrl)
      {
        <text>
        setTimeout(function () { window.location.reload(); }, 5000);
        </text>
      }
    })();
  </script>
}
