@page "/connect/telegram"
@model SuperChat.Web.Pages.Connect.TelegramModel
@{
  ViewData["Title"] = "Connect Telegram";
}

<section class="stack">
  <div class="section-card">
    <p class="eyebrow">Bridge orchestration</p>
    <h1>Connect Telegram without exposing Element</h1>
    <p>Your hidden Matrix identity is provisioned automatically. The app opens a private management room with the bridge, waits for the login prompt, and then starts syncing real Telegram messages.</p>

    <dl class="definition-grid">
      <div>
        <dt>Matrix user</dt>
        <dd>@Model.MatrixUserId</dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd>@Model.Connection.State</dd>
      </div>
      <div>
        <dt>Last sync</dt>
        <dd>@(Model.Connection.LastSyncedAt?.ToString("u") ?? "waiting")</dd>
      </div>
    </dl>

    <form method="post">
      <button type="submit" class="button primary">Start Telegram connection</button>
    </form>

    @if (Model.Connection.WebLoginUrl is not null)
    {
      <p class="notice">Bridge web login: <a href="@Model.Connection.WebLoginUrl">@Model.Connection.WebLoginUrl</a></p>
    }
    else if (Model.Connection.State == SuperChat.Domain.Model.TelegramConnectionState.BridgePending)
    {
      <p class="notice">The bridge is preparing the login prompt. Refresh this page in a few seconds to pick up the web login link.</p>
    }

    <div class="hero-actions">
      <a class="button secondary" asp-page="/Dashboard/Today">Open Today</a>
      <a class="button secondary" asp-page="/Settings/Connections">Inspect connection details</a>
    </div>

    <p class="hint">In development mode the app still seeds sample messages so the product surface remains inspectable without a live Telegram account.</p>
  </div>
</section>
