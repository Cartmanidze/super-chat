@page "/connect/telegram"
@model SuperChat.Web.Pages.Connect.TelegramModel
@{
  ViewData["Title"] = T["ConnectTelegram.PageTitle"];
}

<section class="stack">
  <div class="section-card">
    <p class="eyebrow">@T["ConnectTelegram.Eyebrow"]</p>
    <h1>@T["ConnectTelegram.Title"]</h1>
    <p>@T["ConnectTelegram.Description"]</p>

    <dl class="definition-grid">
      <div>
        <dt>@T["ConnectTelegram.MatrixUser"]</dt>
        <dd>@(Model.MatrixUserId ?? T["Common.Pending"])</dd>
      </div>
      <div>
        <dt>@T["Common.Status"]</dt>
        <dd>@UiText.ConnectionState(Model.Connection.State.ToString())</dd>
      </div>
      <div>
        <dt>@T["Common.LastSync"]</dt>
        <dd>@(Model.Connection.LastSyncedAt?.ToString("u") ?? T["Common.Waiting"])</dd>
      </div>
    </dl>

    <form method="post">
      <button type="submit" class="button primary">@T["ConnectTelegram.StartButton"]</button>
    </form>

    @if (Model.Connection.WebLoginUrl is not null)
    {
      <p class="notice">@T["ConnectTelegram.BridgeWebLogin"] <a href="@Model.Connection.WebLoginUrl">@Model.Connection.WebLoginUrl</a></p>
    }
    else if (Model.Connection.State == SuperChat.Domain.Model.TelegramConnectionState.BridgePending)
    {
      <p class="notice">@T["ConnectTelegram.BridgePendingNotice"]</p>
    }

    <div class="hero-actions">
      <a class="button secondary" asp-page="/Dashboard/Today">@T["ConnectTelegram.OpenToday"]</a>
      <a class="button secondary" asp-page="/Settings/Connections">@T["ConnectTelegram.InspectDetails"]</a>
    </div>

    <p class="hint">@T["ConnectTelegram.DevModeHint"]</p>
  </div>
</section>
