@page "/connect/telegram"
@using SuperChat.Domain.Features.Integrations
@model SuperChat.Web.Pages.Connect.TelegramModel
@{
  ViewData["Title"] = T["ConnectTelegram.PageTitle"];
  var state = Model.Connection.State;
  var connected = state == IntegrationConnectionState.Connected;
  var pending = state == IntegrationConnectionState.Pending;
  var error = state == IntegrationConnectionState.Error;
  var requiresSetup = state == IntegrationConnectionState.RequiresSetup;
  var hasActionUrl = Model.Connection.ActionUrl is not null;
  var loginStep = Model.Connection.ChatLoginStep;
  var isLoginFlow = loginStep is not null;
  var canReconnect = connected || error || pending;
}

<section class="page-stack">
  <div class="page-hero">
    <div class="page-hero-copy">
      <p class="section-kicker">@T["ConnectTelegram.Eyebrow"]</p>
      <h1>Подключение Telegram</h1>
      <p class="page-intro">
        Подключение происходит изнутри SuperChat. После этого продукт начнёт собирать обещания, follow-up'ы,
        встречи и важные сигналы прямо из ваших рабочих переписок.
      </p>
    </div>
    <span class="status-badge @(connected ? "status-success" : pending ? "status-warning" : error ? "status-danger" : "status-neutral")">
      @UiText.ConnectionState(state.ToString())
    </span>
  </div>

  <div class="split-panel">
    <section class="premium-card connection-panel">
      <div class="section-headline">
        <div>
          <p class="section-kicker">Статус подключения</p>
          <h2>@(connected ? "Telegram подключён" : isLoginFlow ? "Вход в Telegram" : pending ? "Ожидание подключения" : error ? "Ошибка подключения" : "Подключите Telegram")</h2>
        </div>
      </div>

      <dl class="detail-grid">
        <div class="detail-row">
          <dt>@T["ConnectTelegram.MatrixUser"]</dt>
          <dd>@(Model.MatrixUserId ?? "Будет создан автоматически")</dd>
        </div>
        <div class="detail-row">
          <dt>@T["Common.Status"]</dt>
          <dd>@UiText.ConnectionState(state.ToString())</dd>
        </div>
        <div class="detail-row">
          <dt>@T["Common.LastSync"]</dt>
          <dd>@(Model.Connection.LastSyncedAt?.ToLocalTime().ToString("dd.MM.yyyy, HH:mm") ?? "Ещё не синхронизировано")</dd>
        </div>
      </dl>

      @if (isLoginFlow)
      {
        <div class="inline-alert inline-alert-info">
          @if (loginStep == "phone")
          {
            <strong>Шаг 1 из 3.</strong>
            <span>Введите номер телефона вашего Telegram-аккаунта.</span>
          }
          else if (loginStep == "code")
          {
            <strong>Шаг 2 из 3.</strong>
            <span>Введите код подтверждения, отправленный в Telegram.</span>
          }
          else if (loginStep == "password")
          {
            <strong>Шаг 3 из 3.</strong>
            <span>Введите пароль двухфакторной аутентификации (2FA).</span>
          }
        </div>

        <form method="post" asp-page-handler="SubmitLoginInput" class="login-step-form">
          @if (loginStep == "phone")
          {
            <div class="dialog-field">
              <label for="login-input">Номер телефона</label>
              <input id="login-input" type="tel" name="LoginInput" placeholder="+7 999 123-45-67"
                     required autofocus autocomplete="tel" />
            </div>
            <button type="submit" class="app-button app-button-primary">Отправить номер</button>
          }
          else if (loginStep == "code")
          {
            <div class="dialog-field">
              <label for="login-input">Код подтверждения</label>
              <input id="login-input" type="text" name="LoginInput" placeholder="12345"
                     required autofocus autocomplete="one-time-code" inputmode="numeric" />
            </div>
            <button type="submit" class="app-button app-button-primary">Подтвердить код</button>
          }
          else if (loginStep == "password")
          {
            <div class="dialog-field">
              <label for="login-input">Пароль 2FA</label>
              <input id="login-input" type="password" name="LoginInput" placeholder="Пароль двухфакторной аутентификации"
                     required autofocus autocomplete="current-password" />
            </div>
            <button type="submit" class="app-button app-button-primary">Войти</button>
          }
        </form>
      }
      else if (hasActionUrl)
      {
        <div class="inline-alert inline-alert-info">
          <strong>Следующий шаг.</strong>
          <span>Откройте ссылку ниже для входа через Telegram bridge:</span>
          <a class="inline-link" href="@Model.Connection.ActionUrl" target="_blank" rel="noopener">Открыть Telegram Login</a>
        </div>
      }
      else if (pending)
      {
        <div class="inline-alert inline-alert-info">
          Bridge готовит форму входа. Страница обновится автоматически.
        </div>
      }
      else if (error)
      {
        <div class="inline-alert inline-alert-error">
          Произошла ошибка при подключении. Попробуйте переподключиться.
        </div>
      }
      else if (requiresSetup)
      {
        <div class="inline-alert inline-alert-info">
          Требуется настройка Matrix-аккаунта. Обратитесь к администратору.
        </div>
      }

      @if (!isLoginFlow)
      {
        <div class="feature-stack">
          <article class="feature-chip-card">
            <strong>Обещания</strong>
            <span>Кому и что вы пообещали в переписках.</span>
          </article>
          <article class="feature-chip-card">
            <strong>Follow-ups</strong>
            <span>Где от вас ждут ответ или следующий шаг.</span>
          </article>
          <article class="feature-chip-card">
            <strong>Встречи</strong>
            <span>Временные договорённости и ближайшие созвоны.</span>
          </article>
          <article class="feature-chip-card">
            <strong>Важные сигналы</strong>
            <span>Смысловые куски, которые стоит поднять на поверхность.</span>
          </article>
        </div>
      }

      <div class="inline-actions">
        @if (connected)
        {
          <form method="post" asp-page-handler="StartChatLogin" style="display:inline">
            <button type="submit" class="app-button app-button-primary">Переподключить Telegram</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else if (isLoginFlow)
        {
          <form method="post" asp-page-handler="StartChatLogin" style="display:inline">
            <button type="submit" class="app-button app-button-secondary">Начать заново</button>
          </form>
        }
        else if (pending)
        {
          <form method="post" asp-page-handler="StartChatLogin" style="display:inline">
            <button type="submit" class="app-button app-button-secondary">Начать заново</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else if (error)
        {
          <form method="post" asp-page-handler="StartChatLogin" style="display:inline">
            <button type="submit" class="app-button app-button-primary">Повторить подключение</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
        else
        {
          <form method="post" asp-page-handler="StartChatLogin" style="display:inline">
            <button type="submit" class="app-button app-button-primary">Подключить Telegram</button>
          </form>
          <a class="app-button app-button-secondary" asp-page="/Today">Открыть Today</a>
        }
      </div>
    </section>

    <aside class="premium-card connection-aside">
      <p class="section-kicker">Как это работает</p>
      <h2>Три шага подключения</h2>
      <ol class="timeline-list">
        <li class="@(loginStep == "phone" ? "timeline-active" : loginStep is "code" or "password" ? "timeline-done" : "")">
          <strong>1. Номер телефона</strong>
          <span>Введите номер — bridge запустит безопасный Telegram login.</span>
        </li>
        <li class="@(loginStep == "code" ? "timeline-active" : loginStep == "password" ? "timeline-done" : "")">
          <strong>2. Код подтверждения</strong>
          <span>Telegram пришлёт код — введите его здесь.</span>
        </li>
        <li class="@(loginStep == "password" ? "timeline-active" : "")">
          <strong>3. 2FA (если включён)</strong>
          <span>Если у аккаунта есть пароль — ещё один шаг.</span>
        </li>
      </ol>

      <div class="privacy-note">
        <strong>Важно.</strong>
        <p>SuperChat не заменяет Telegram. Он строит поверх него слой рабочей памяти и объяснимых сигналов.</p>
      </div>
    </aside>
  </div>
</section>

@section Scripts
{
  <script>
    (function () {
      @if (isLoginFlow)
      {
        <text>
        var refreshTimer = setTimeout(function () { window.location.reload(); }, 5000);
        var loginInput = document.getElementById('login-input');
        if (loginInput) {
          loginInput.addEventListener('focus', function () { clearTimeout(refreshTimer); });
          loginInput.addEventListener('blur', function () {
            if (!loginInput.value.trim()) {
              refreshTimer = setTimeout(function () { window.location.reload(); }, 5000);
            }
          });
        }
        </text>
      }
      else if (pending && !hasActionUrl)
      {
        <text>
        setTimeout(function () { window.location.reload(); }, 5000);
        </text>
      }
    })();
  </script>
}
