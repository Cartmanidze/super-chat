@page "/search"
@model SuperChat.Web.Pages.Search.IndexModel
@{
  ViewData["Title"] = T["Search.PageTitle"];
}

<section class="stack">
  <div class="section-head">
    <p class="eyebrow">@T["Search.Eyebrow"]</p>
    <h1>@T["Search.Title"]</h1>
  </div>

  <form method="get" class="search-form">
    <input asp-for="Query" placeholder="@T["Search.Placeholder"]" />
    <button type="submit" class="button primary">@T["Search.Button"]</button>
  </form>

  @if (Model.Results.Count == 0 && !string.IsNullOrWhiteSpace(Model.Query))
  {
    <div class="empty-state">
      <p>@T["Search.NoMatches", Model.Query]</p>
    </div>
  }
  else if (Model.Results.Count > 0)
  {
    <div class="stack">
      @foreach (var result in Model.Results)
      {
        <article class="section-card">
          <span class="pill">@UiText.Kind(result.Kind)</span>
          <h2>@UiText.CardTitle(result.Title)</h2>
          <p>@result.Summary</p>
          <small>@UiText.SourceRoom(result.SourceRoom) | @result.ObservedAt.ToString("u")</small>
        </article>
      }
    </div>
  }
</section>
