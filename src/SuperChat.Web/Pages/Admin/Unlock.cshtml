@page "/admin/unlock"
@model SuperChat.Web.Pages.Admin.UnlockModel
@{
  ViewData["Title"] = "Пароль админки";
}

<section class="auth-screen">
  <div class="auth-card">
    <p class="auth-kicker">Admin</p>
    <h1>Подтвердите пароль админки</h1>
    <p class="auth-copy">
      Сначала вы входите по magic link, затем отдельно подтверждаете доступ к админке паролем.
    </p>

    @if (!Model.PasswordConfigured)
    {
      <p class="status-note">Пароль админки не настроен в конфигурации. Задайте `SuperChat__AdminPasswordHash` в env.</p>
    }
    else
    {
      <form method="post" class="auth-form">
        <input asp-for="ReturnUrl" type="hidden" />
        <label asp-for="Password" class="visually-hidden">Пароль админки</label>
        <input asp-for="Password" type="password" autocomplete="current-password" placeholder="Введите пароль" />
        <button type="submit" class="send-button wide">Открыть админку</button>
      </form>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
      <p class="status-note">@Model.ErrorMessage</p>
    }
  </div>
</section>
