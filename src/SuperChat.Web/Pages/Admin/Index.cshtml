@page "/admin"
@model SuperChat.Web.Pages.Admin.IndexModel
@{
  ViewData["Title"] = "Админка";
  var activeInvites = Model.Invites.Count(item => item.IsActive);
}

<section class="page-stack">
  <div class="page-hero insight-hero">
    <div class="page-hero-copy">
      <p class="section-kicker">Admin</p>
      <h1>Доступы и операции</h1>
      <p class="page-intro">
        Здесь остались pilot-инвайты и базовые административные операции.
        Операционные метрики и дашборды теперь живут в Grafana/Prometheus.
        Время на странице показывается в timezone <strong>@Model.DisplayTimeZoneId</strong>.
      </p>
    </div>

    <div class="metric-grid">
      <article class="metric-card">
        <small>Всего инвайтов</small>
        <strong>@Model.Invites.Count</strong>
      </article>
      <article class="metric-card">
        <small>Активных email</small>
        <strong>@activeInvites</strong>
      </article>
      <article class="metric-card">
        <small>Timezone</small>
        <strong>@Model.DisplayTimeZoneId</strong>
      </article>
    </div>
  </div>

  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    <div class="inline-alert inline-alert-info">
      <strong>Изменение сохранено</strong>
      <span>@Model.StatusMessage</span>
    </div>
  }

  @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
  {
    <div class="inline-alert inline-alert-error">
      <strong>Не получилось сохранить</strong>
      <span>@Model.ErrorMessage</span>
    </div>
  }

  <div class="settings-grid">
    <section class="premium-card settings-card">
      <div class="section-headline">
        <div>
          <p class="section-kicker">Allowlist</p>
          <h2>Добавить email в magic link</h2>
          <p>Новый email сразу попадает в `pilot_invites` и может запросить вход. Конфиговый bootstrap-список больше не используется.</p>
        </div>
      </div>

      <form method="post" asp-page-handler="AddInvite" class="auth-form">
        <div class="dialog-field">
          <label asp-for="InviteEmail">Email</label>
          <input asp-for="InviteEmail" type="email" autocomplete="email" placeholder="name@example.com" />
        </div>

        <button type="submit" class="app-button app-button-primary">Добавить в allowlist</button>
      </form>
    </section>

    <section class="premium-card settings-card">
      <div class="section-headline">
        <div>
          <p class="section-kicker">Invites</p>
          <h2>Текущий список инвайтов</h2>
          <p>Активные адреса могут сразу запрашивать magic link.</p>
        </div>
        <span class="count-pill">@activeInvites</span>
      </div>

      @if (Model.Invites.Count == 0)
      {
        <div class="empty-state">
          <p>Список пока пуст.</p>
        </div>
      }
      else
      {
        <ol class="timeline-list">
          @foreach (var invite in Model.Invites)
          {
            <li>
              <div class="signal-head">
                <strong>@invite.Email</strong>
                <span class="status-badge @(invite.IsActive ? "status-success" : "status-neutral")">
                  @(invite.IsActive ? "Активен" : "Выключен")
                </span>
              </div>
              <span>Добавил: @invite.InvitedBy</span>
              <span>@Model.FormatTimestamp(invite.InvitedAt)</span>
            </li>
          }
        </ol>
      }
    </section>
  </div>
</section>
