ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__SuperChatDb=Host=localhost;Port=5432;Database=superchat_app;Username=postgres;Password=postgres
Persistence__Provider=Postgres
Persistence__ConnectionString=Host=localhost;Port=5432;Database=superchat_app;Username=postgres;Password=postgres
Persistence__AutoInitialize=true
Chunking__Enabled=true
Chunking__PollSeconds=5
Chunking__MaxGapMinutes=15
Chunking__MaxMessagesPerChunk=8
Chunking__MaxChunkCharacters=1600
ChunkIndexing__Enabled=true
ChunkIndexing__PollSeconds=10
ChunkIndexing__BatchSize=20
MeetingProjection__Enabled=true
MeetingProjection__PollSeconds=15
Retrieval__Enabled=true
Retrieval__PrefetchLimit=24
Retrieval__ResultLimit=8
ChatAnswering__Enabled=true
ChatAnswering__MaxContextChunks=5
ChatAnswering__MaxEvidenceItems=3
ChatAnswering__MaxContextCharacters=4800
ChatAnswering__MaxOutputTokens=500
SuperChat__BaseUrl=https://localhost:8080
SuperChat__AllowedEmails__0=pilot@example.com
SuperChat__AllowedEmails__1=founder@example.com
SuperChat__MagicLinkMinutes=15
SuperChat__ApiSessionDays=30
SuperChat__DevSeedSampleData=true

DeepSeek__ApiKey=
DeepSeek__Model=deepseek-chat
DeepSeek__BaseUrl=https://api.deepseek.com
Qdrant__BaseUrl=http://localhost:6333
Qdrant__ApiKey=
Qdrant__AutoInitialize=false
Qdrant__MemoryCollectionName=memory_bgem3_v1
Qdrant__DenseVectorName=text-dense
Qdrant__SparseVectorName=text-sparse
Qdrant__DenseVectorSize=1024
Embedding__Enabled=true
Embedding__Backend=LocalService
Embedding__BaseUrl=http://localhost:7291
Embedding__TimeoutSeconds=60
Embedding__DenseVectorSize=1024
Embedding__YandexBaseUrl=https://ai.api.cloud.yandex.net
Embedding__YandexApiKey=
Embedding__YandexFolderId=
Embedding__YandexDocModelUri=
Embedding__YandexQueryModelUri=
Embedding__YandexDocModelName=text-search-doc
Embedding__YandexQueryModelName=text-search-query
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_PORT=7291
EMBEDDING_DEVICE=cpu
EMBEDDING_DENSE_VECTOR_SIZE=1024
EMBEDDING_INSTALL_BGE=0

Matrix__HomeserverUrl=https://matrix.localhost
Matrix__AdminAccessToken=
Matrix__UserIdPrefix=superchat

TelegramBridge__BotUserId=@telegrambot:matrix.localhost
TelegramBridge__WebLoginBaseUrl=https://bridge.localhost/public

Email__FromSender=Super Chat <hello@superchat.local>
Email__SmtpHost=localhost
