POSTGRES_MULTIPLE_DATABASES=superchat_app,synapse,mautrix_telegram

SUPERCHAT_PERSISTENCE_CONNECTION=Host=postgres;Port=5432;Database=superchat_app;Username=postgres;Password=replace-me

SUPERCHAT_WEB_HOST=app.example.com
SUPERCHAT_API_HOST=api.example.com
CADDY_ACME_EMAIL=ops@example.com

SUPERCHAT_ALLOWED_EMAILS__0=pilot@example.com
