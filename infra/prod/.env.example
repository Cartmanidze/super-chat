POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_MULTIPLE_DATABASES=superchat_app

GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=
GHCR_TOKEN=
SUPERCHAT_WEB_IMAGE=ghcr.io/cartmanidze/superchat-web:main
SUPERCHAT_API_IMAGE=ghcr.io/cartmanidze/superchat-api:main
SUPERCHAT_WORKER_IMAGE=ghcr.io/cartmanidze/superchat-worker:main
SUPERCHAT_DB_MIGRATOR_IMAGE=ghcr.io/cartmanidze/superchat-db-migrator:main

SUPERCHAT_PERSISTENCE_CONNECTION=Host=postgres;Port=5432;Database=superchat_app;Username=postgres;Password=replace-me

# Production hostnames use super-chat.org.
SUPERCHAT_WEB_HOST=app.super-chat.org
SUPERCHAT_API_HOST=api.super-chat.org
GRAFANA_HOST=grafana.example.com
CADDY_ACME_EMAIL=ops@example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
SUPERCHAT_LOG_ENVIRONMENT=prod
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5
LOG_ALERT_WEBHOOK_URL=https://example.invalid/superchat-log-alerts

SUPERCHAT_ADMIN_EMAILS__0=admin@example.com
SUPERCHAT_ADMIN_PASSWORD_HASH=
SUPERCHAT_BASE_URL=https://app.super-chat.org
SUPERCHAT_API_SESSION_DAYS=30
SUPERCHAT_MAGIC_LINK_MINUTES=15
SUPERCHAT_DEV_SEED_SAMPLE_DATA=false
SUPERCHAT_ENABLE_GROUP_MESSAGES=false
SUPERCHAT_MAX_GROUP_MEMBERS=30
SUPERCHAT_TODAY_TIME_ZONE_ID=Europe/Moscow
CHUNKING_ENABLED=true
CHUNKING_POLL_SECONDS=5
CHUNKING_MAX_GAP_MINUTES=15
CHUNKING_MAX_MESSAGES_PER_CHUNK=8
CHUNKING_MAX_CHUNK_CHARACTERS=1600
CHUNK_INDEXING_ENABLED=true
CHUNK_INDEXING_POLL_SECONDS=10
CHUNK_INDEXING_BATCH_SIZE=20
MEETING_PROJECTION_ENABLED=true
MEETING_PROJECTION_POLL_SECONDS=15
PIPELINE_MESSAGING_ENABLED=true
PIPELINE_MESSAGING_INPUT_QUEUE_NAME=superchat-pipeline
PIPELINE_MESSAGING_TRANSPORT_TABLE_NAME=rebus_messages
PIPELINE_MESSAGING_WORKERS=1
PIPELINE_MESSAGING_MAX_PARALLELISM=1
RETRIEVAL_ENABLED=true
RETRIEVAL_PREFETCH_LIMIT=24
RETRIEVAL_RESULT_LIMIT=8
CHAT_ANSWERING_ENABLED=true
CHAT_ANSWERING_MAX_CONTEXT_CHUNKS=5
CHAT_ANSWERING_MAX_EVIDENCE_ITEMS=3
CHAT_ANSWERING_MAX_CONTEXT_CHARACTERS=4800
CHAT_ANSWERING_MAX_OUTPUT_TOKENS=500
QDRANT_BASE_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_AUTO_INITIALIZE=true
QDRANT_MEMORY_COLLECTION_NAME=memory_bgem3_v1
QDRANT_DENSE_VECTOR_NAME=text-dense
QDRANT_SPARSE_VECTOR_NAME=text-sparse
QDRANT_DENSE_VECTOR_SIZE=1024
EMBEDDING_ENABLED=true
EMBEDDING_BACKEND=LocalService
EMBEDDING_BASE_URL=http://embedding-service:7291
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_DENSE_VECTOR_SIZE=1024
EMBEDDING_YANDEX_BASE_URL=https://ai.api.cloud.yandex.net
EMBEDDING_YANDEX_API_KEY=
EMBEDDING_YANDEX_FOLDER_ID=
EMBEDDING_YANDEX_DOC_MODEL_URI=
EMBEDDING_YANDEX_QUERY_MODEL_URI=
EMBEDDING_YANDEX_DOC_MODEL_NAME=text-search-doc
EMBEDDING_YANDEX_QUERY_MODEL_NAME=text-search-query
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_PORT=7291
EMBEDDING_DEVICE=cpu
EMBEDDING_INSTALL_BGE=0

# Telegram userbot (Telethon sidecar).
# Get API_ID/HASH at https://my.telegram.org.
# TELEGRAM_SESSION_ENCRYPTION_KEY = `openssl rand -base64 32`.
# TELEGRAM_USERBOT_HMAC_SECRET = `openssl rand -hex 32`.
TELEGRAM_USERBOT_ENABLED=false
TELEGRAM_USERBOT_PORT=7491
TELEGRAM_USERBOT_LOG_LEVEL=INFO
TELEGRAM_USERBOT_BASE_URL=http://telegram-userbot-service:7491
TELEGRAM_USERBOT_TIMEOUT_SECONDS=30
TELEGRAM_USERBOT_DATABASE_URL=postgresql://postgres:replace-me@postgres:5432/superchat_app
TELEGRAM_USERBOT_SUPERCHAT_API_URL=http://superchat-worker:8080
TELEGRAM_USERBOT_HMAC_SECRET=replace-me
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_ENCRYPTION_KEY=

# Max userbot (skeleton for the future Max reverse-engineered client).
# Disabled by default until the protocol work lands.
MAX_USERBOT_ENABLED=false
MAX_USERBOT_PORT=7591
MAX_USERBOT_LOG_LEVEL=INFO
MAX_USERBOT_BASE_URL=http://max-userbot-service:7591
MAX_USERBOT_TIMEOUT_SECONDS=30
MAX_USERBOT_HMAC_SECRET=replace-me

EMAIL_FROM=Super Chat <hello@example.com>
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_ENABLE_SSL=true

DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL=deepseek-reasoner
RESOLUTION_ENABLE_DUE_MEETINGS_SWEEP=true
RESOLUTION_DUE_MEETINGS_SWEEP_MINUTES=10

TEXT_ENRICHMENT_ENABLED=false
TEXT_ENRICHMENT_BASE_URL=http://text-enrichment-service:7391
TEXT_ENRICHMENT_TIMEOUT_SECONDS=20
TEXT_ENRICHMENT_PORT=7391
TEXT_ENRICHMENT_HEIDELTIME_LANGUAGE=Russian
TEXT_ENRICHMENT_HEIDELTIME_DOCUMENT_TYPE=colloquial
TEXT_ENRICHMENT_LOG_LEVEL=INFO
